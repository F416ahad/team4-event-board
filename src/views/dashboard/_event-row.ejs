<div class="p-4 border border-slate-200 rounded-xl bg-white shadow-sm mb-3">
  <div class="flex items-start justify-between gap-3">
    <div>
      <h3 class="text-lg font-semibold"><%= event.title %></h3>
      <p class="text-slate-500 text-sm">
        <%= event.date ? new Date(event.date).toLocaleString() : 'No date' %>
        <% if (event.endTime) { %>
          &nbsp;&ndash;&nbsp;<%= new Date(event.endTime).toLocaleString() %>
        <% } %>
      </p>
    </div>
    <% if (event.category) { %>
      <span class="text-xs px-2 py-1 rounded bg-slate-100 text-slate-600 capitalize whitespace-nowrap">
        <%= event.category %>
      </span>
    <% } %>
  </div>

  <div class="mt-3 flex gap-3">
    <a href="/events/<%= event.id %>"
       class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm">
      View Event
    </a>

    <% if (session.authenticatedUser.role === "admin" ||
           session.authenticatedUser.userId === event.createdByUserId) { %>
      <a href="/events/<%= event.id %>/edit"
         class="px-4 py-2 bg-slate-700 text-white rounded-lg hover:bg-slate-800 text-sm">
        Edit
      </a>
    <% } %>
  </div>
</div>
