<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
<nav class="bg-white border-b border-slate-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16">
      <div class="flex items-center gap-8">
        <a href="/" class="text-xl font-bold text-blue-600">Project Starter</a>
        
        <div class="hidden sm:flex gap-4">
          <a href="/events" class="text-sm font-medium text-slate-600 hover:text-blue-600">All Events</a>
          
          <%# Only show these links if the user is actually logged in %>
          <% if (typeof session !== 'undefined' && session?.authenticatedUser) { %>
            <a href="/savedEvents" class="text-sm font-medium text-slate-600 hover:text-blue-600">My Saved Events</a>
            <a href="/dashboard" class="text-sm font-medium text-slate-600 hover:text-blue-600">Dashboard</a>
          <% } %>
        </div>

      </div>
      <div class="flex items-center gap-4">
        
        <%# Safely check for the user before printing their name %>
        <% if (typeof session !== 'undefined' && session?.authenticatedUser) { %>
          <span class="text-xs text-slate-400">Signed in as <%= session.authenticatedUser.displayName %></span>
          <a href="/logout" class="text-sm font-medium text-red-500 hover:text-red-700">Log out</a>
        <% } else { %>
          <a href="/login" class="text-sm font-medium text-blue-600 hover:text-blue-800">Log in</a>
        <% } %>

      </div>
    </div>
  </div>
</nav>
