<%# 
  Create new event form.
  Only accessible to users with 'staff' or 'admin' role.
  Submits POST /events with title and optional capacity.
%>

<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <h1 class="text-3xl font-bold text-slate-900 mb-3">Create New Event</h1>
  <p class="text-slate-500">
    Fill in the event details. Capacity is optional – leave empty for unlimited.
  </p>
</section>

<% if (typeof error !== 'undefined' && error) { %>
  <%- include("../partials/error", { message: error }) %>
<% } %>

<section class="max-w-2xl p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <form class="grid gap-4" method="post" action="/events">
    <div>
      <label for="title" class="block text-sm font-medium text-slate-700 mb-1">Title *</label>
      <input
        type="text"
        id="title"
        name="title"
        required
        class="w-full px-3 py-2 border border-slate-300 rounded-xl bg-white focus:outline-2 focus:outline-blue-500/20 focus:border-blue-500"
      />
    </div>

    <div>
      <label for="capacity" class="block text-sm font-medium text-slate-700 mb-1">Capacity (optional)</label>
      <input
        type="number"
        id="capacity"
        name="capacity"
        min="1"
        class="w-full px-3 py-2 border border-slate-300 rounded-xl bg-white focus:outline-2 focus:outline-blue-500/20 focus:border-blue-500"
      />
      <p class="text-xs text-slate-400 mt-1">Leave empty for no limit</p>
    </div>

    <button
      type="submit"
      class="mt-2 px-4 py-2.5 rounded-lg bg-blue-600 text-white font-medium cursor-pointer hover:bg-blue-700"
    >
      Create Event
    </button>
  </form>

  <div class="mt-6 pt-4 border-t border-slate-200">
    <a href="/events" class="text-blue-600 hover:underline">&larr; Back to Events</a>
  </div>
</section>