<%#
  Event detail page.
  Shows event information, RSVP toggle button (HTMX), and comments section (HTMX).
  Requires user to be authenticated.
%>

<section class="mb-5 p-5 sm:p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <h1 class="text-2xl sm:text-3xl font-bold text-slate-900 mb-2"><%= event ? event.title : 'Event Details' %></h1>
  <p class="text-slate-500">View event details, RSVP, and join the conversation.</p>
</section>

<% if (typeof error !== 'undefined' && error) { %>
  <%- include("../partials/error", { message: error }) %>
<% } %>

<% if (event) { %>
  <div class="grid gap-6">

    <%# ============================
        EVENT INFO CARD
        ============================ %>
    <div class="p-6 border border-slate-200 rounded-2xl bg-white shadow-md">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <p class="text-sm text-slate-500">Date</p>
          <p class="font-medium"><%= new Date(event.date).toLocaleString() %></p>
        </div>
        <div>
          <p class="text-sm text-slate-500">Status</p>
          <p class="font-medium capitalize <%= event.status === 'cancelled' ? 'text-red-600' : 'text-green-600' %>">
            <%= event.status %>
          </p>
        </div>
        <div>
          <p class="text-sm text-slate-500">Capacity</p>
          <p class="font-medium"><%= event.capacity ? event.capacity : 'Unlimited' %></p>
        </div>
      </div>

      <% const canEditEvent = session?.authenticatedUser &&
         (session.authenticatedUser.role === "admin" ||
         (session.authenticatedUser.role === "staff" && session.authenticatedUser.userId === event.createdByUserId)); %>

      <% if (canEditEvent) { %>
        <div class="mt-4">
          <a href="/events/<%= event.id %>/edit"
             class="inline-block px-4 py-2 rounded-lg bg-slate-700 text-white font-medium hover:bg-slate-800 transition-colors">
            Edit Event
          </a>
        </div>
      <% } %>

      <%# ============================
          WAITLIST / RSVP STATUS BANNERS
          ============================ %>
      <% if (typeof userRsvp !== 'undefined' && userRsvp) { %>

        <% if (userRsvp.status === "going") { %>
          <div class="mt-4 p-3 rounded-lg bg-green-100 text-green-800 border border-green-300">
            You are attending this event.
          </div>

        <% } else if (userRsvp.status === "waitlisted") { %>
          <div class="mt-4 p-3 rounded-lg bg-yellow-100 text-yellow-800 border border-yellow-300">
            You are on the waitlist.
            <% if (typeof waitlistPosition !== "undefined" && waitlistPosition !== null) { %>
              <br>Your position: <strong>#<%= waitlistPosition %></strong>
            <% } %>
          </div>
        <% } %>

      <% } %>

      <%# ============================
          ACTION BAR: RSVP & SAVE BUTTONS (HTMX)
          ============================ %>
      <div class="mt-6 pt-4 border-t border-slate-200 flex flex-col sm:flex-row items-start sm:items-center gap-4">
        
        <div id="rsvp-status" class="flex flex-col items-start">
          <%- include("../partials/save-button", { event: event, isSaved: isSaved }) %>
            <% } %>
          </button>
          <p class="text-sm text-slate-500 mt-1">
            Attendees going: <span><%= typeof attendeeCount !== 'undefined' ? attendeeCount : 0 %></span>
          </p>
        </div>

        <div class="sm:ml-auto">
          <% if (typeof isSaved !== 'undefined' && isSaved) { %>
            <button hx-post="/events/<%= event.id %>/save" hx-swap="outerHTML" class="flex items-center gap-2 px-4 py-2.5 text-sm font-medium text-blue-700 bg-blue-50 border border-blue-200 rounded-lg hover:bg-blue-100 transition-all shadow-sm">
              <svg class="w-5 h-5 text-blue-600" fill="currentColor" viewBox="0 0 20 20"><path d="M5 4a2 2 0 012-2h6a2 2 0 012 2v14l-5-2.5L5 18V4z"></path></svg>
              Saved
            </button>
          <% } else { %>
            <button hx-post="/events/<%= event.id %>/save" hx-swap="outerHTML" class="flex items-center gap-2 px-4 py-2.5 text-sm font-medium text-slate-700 bg-white border border-slate-300 rounded-lg hover:bg-slate-50 transition-all shadow-sm">
              <svg class="w-5 h-5 text-slate-400 group-hover:text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"></path></svg>
              Save for Later
            </button>
          <% } %>
        </div>

      </div>
    </div>

    <%# ============================
        COMMENTS SECTION (HTMX)
        ============================ %>
    <div class="p-6 border border-slate-200 rounded-2xl bg-white shadow-md">
      <h2 class="text-xl font-semibold mb-4">Comments</h2>

      <div id="comment-list-container"
           hx-get="/events/<%= event.id %>/comments/partial"
           hx-trigger="load, commentChanged from:body"
           hx-target="#comment-list-container"
           hx-swap="outerHTML">
        <div class="text-center py-8 text-slate-400">Loading comments...</div>
      </div>
    </div>

    <div>
      <a href="/events" class="text-blue-600 hover:underline">&larr; Back to Events</a>
    </div>

  </div>

<% } else { %>
  <div class="p-6 border border-red-200 rounded-2xl bg-red-50 text-red-800">
    <p>Event not found.</p>
  </div>
<% } %>