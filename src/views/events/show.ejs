<%# 
  Event detail page.
  Shows event information, RSVP toggle button (with fetch API), and comments section (HTMX).
  Requires user to be authenticated.
%>

<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <h1 class="text-3xl font-bold text-slate-900 mb-2"><%= event ? event.title : 'Event Details' %></h1>
  <p class="text-slate-500">View event details, RSVP, and join the conversation.</p>
</section>

<% if (typeof error !== 'undefined' && error) { %>
  <%- include("../partials/error", { message: error }) %>
<% } %>

<% if (event) { %>
  <div class="grid gap-6">
    <%# Event info card %>
    <div class="p-6 border border-slate-200 rounded-2xl bg-white shadow-md">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <p class="text-sm text-slate-500">Date</p>
          <p class="font-medium"><%= new Date(event.date).toLocaleString() %></p>
        </div>
        <div>
          <p class="text-sm text-slate-500">Status</p>
          <p class="font-medium capitalize <%= event.status === 'cancelled' ? 'text-red-600' : 'text-green-600' %>">
            <%= event.status %>
          </p>
        </div>
        <div>
          <p class="text-sm text-slate-500">Capacity</p>
          <p class="font-medium"><%= event.capacity ? event.capacity : 'Unlimited' %></p>
        </div>
      </div>

      <%# RSVP Toggle Button (HTMX) %>
      <div class="mt-6 pt-4 border-t border-slate-200" id="rsvp-status">
        <button hx-post="/events/<%= event.id %>/rsvp"
                hx-target="#rsvp-status"
                hx-swap="outerHTML"
                hx-headers='{"X-Requested-With": "XMLHttpRequest"}'
                class="px-6 py-2.5 rounded-lg font-medium transition-colors">
          Loading...
        </button>
        <p class="text-sm text-slate-500 mt-2">Attendees going: <span id="attendee-count-loading">Loading...</span></p>
      </div>
    </div>

    <%# Comments Section (HTMX) %>
    <div class="p-6 border border-slate-200 rounded-2xl bg-white shadow-md">
      <h2 class="text-xl font-semibold mb-4">Comments</h2>
      <div id="comment-list-container" 
           hx-get="/events/<%= event.id %>/comments/partial" 
           hx-trigger="load, commentChanged from:body" 
           hx-target="#comment-list-container" 
           hx-swap="outerHTML">
        <div class="text-center py-8 text-slate-400">Loading comments...</div>
      </div>
    </div>

    <div>
      <a href="/events" class="text-blue-600 hover:underline">&larr; Back to Events</a>
    </div>
  </div>

   <%# all fetch/JavaScript removed, HTMX now handles everything inline %>
  <% } else { %>
  <div class="p-6 border border-red-200 rounded-2xl bg-red-50 text-red-800">
    <p>Event not found.</p>
  </div>
<% } %>