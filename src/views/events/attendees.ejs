<div class="max-w-2xl mx-auto px-4 py-8">
  <h2 class="text-xl font-bold mb-6">Attendees</h2>

  <% [
    { label: 'Attending', key: 'attending' },
    { label: 'Waitlisted', key: 'waitlisted' },
    { label: 'Cancelled', key: 'cancelled' },
  ].forEach(({ label, key }) => { %>
    <div class="mb-6">
      <h3 class="font-semibold text-gray-700 mb-2">
        <%= label %> (<%= attendees[key].length %>)
      </h3>
      <% if (attendees[key].length === 0) { %>
        <p class="text-sm text-gray-400 italic">None.</p>
      <% } else { %>
        <ul class="divide-y border rounded">
          <% attendees[key].forEach(rsvp => { %>
            <li class="px-4 py-2 flex justify-between text-sm">
              <span><%= rsvp.displayName %></span>
              <span class="text-gray-400"><%= new Date(rsvp.createdAt).toLocaleString() %></span>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </div>
  <% }) %>
</div>