  <a href="/archive" class="inline-flex items-center gap-1 text-sm text-slate-500 hover:text-indigo-700 transition-colors">
    &larr; Back to archive
  </a>
</div>

<div class="max-w-3xl mx-auto py-2">
  <%- include('partials/attendee-list', { attendees }) %>
</div>
