<%- include('../partials/header') %> 

<main class="container">
    <article class="event-detail-page">
        <header>
            <h1><%= event.title %></h1>
            <span class="badge"><%= event.category %></span>
        </header>

        <section class="event-meta">
            <p><strong>Location:</strong> <%= event.location %></p>
            <p><strong>Date/Time:</strong> <%= event.startDatetime %></p>
            <p><strong>Capacity:</strong> <%= event.capacity ? event.capacity : "No limit" %></p>
        </section>

        <section class="event-body">
            <h3>Description</h3>
            <p><%= event.description %></p>
        </section>

        <hr>

        <div class="user-actions">
            <% /* Feature 2: Organizer/Admin Controls */ %>
            <% if (session?.user && (session.user.id === event.organizerId || session.user.role === 'admin')) { %>
                <div class="admin-panel">
                    <p><em>Organizer View</em></p>
                    <a href="/events/<%= event.id %>/edit" class="btn btn-edit">Edit Event</a>
                    <button class="btn btn-cancel">Cancel Event</button>
                </div>
            <% } else { %>
                <% /* Sprint 2: HTMX RSVP Section */ %>
                <div id="rsvp-section">
                    <p><strong>Current Attendees:</strong> <span id="count"><%= event.attendeeCount || 0 %></span></p>
                    
                    <% if (session?.user) { %>
                        <button 
                            hx-post="/events/<%= event.id %>/rsvp" 
                            hx-target="#rsvp-section" 
                            hx-swap="outerHTML"
                            class="btn btn-rsvp">
                            RSVP for this Event
                        </button>
                    <% } else { %>
                        <p class="text-sm italic">Please <a href="/login">login</a> to RSVP.</p>
                    <% } %>
                </div>
            <% } %>
        </div>
    </article>
</main>

<%- include('../partials/footer') %>