<%- include('../partials/header') %>

<main class="container mx-auto py-8 px-4 md:px-8 max-w-4xl">
    
    <header class="mb-6 md:mb-10">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-gray-900 tracking-tight">
                <%= event.title %>
            </h1>
            <p class="text-gray-500 mt-2 text-sm md:text-base">Organized by <span class="font-semibold text-gray-700">Team 4</span></p>
        </div>
        <div class="self-start md:self-center">
            <span class="inline-flex items-center px-4 py-1.5 rounded-full text-xs md:text-sm font-bold bg-blue-600 text-white shadow-md">
                <%= event.category %>
            </span>
        </div>
    </div>
</header>

    <!-- Event Detail Card -->
    <article class="bg-white border border-gray-200 rounded-xl shadow-md overflow-hidden">
        
        <section class="p-6 md:p-8 space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                
                <!-- Location -->
                <div class="flex items-start gap-3">
                    <div class="mt-1 text-blue-600">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm font-bold uppercase tracking-wider text-gray-500">Location</p>
                        <p class="text-lg text-gray-800 font-medium"><%= event.location %></p>
                    </div>
                </div>

                <!-- Date & Time (ENHANCED W/ ALPINE.JS) -->
                <div class="flex items-start gap-3" 
                     x-data="{ 
                        eventDate: '<%= event.startDatetime.toISOString() %>',
                        get relativeTime() {
                            const diff = Math.ceil((new Date(this.eventDate) - new Date()) / (1000 * 60 * 60 * 24));
                            if (diff === 0) return 'today';
                            if (diff === 1) return 'tomorrow';
                            if (diff > 1) return `in ${diff} days`;
                            if (diff === -1) return 'yesterday';
                            return diff < -1 ? `${Math.abs(diff)} days ago` : 'past event';
                        }
                     }">
                    <div class="mt-1 text-blue-600">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm font-bold uppercase tracking-wider text-gray-500">Date & Time</p>
                        <p class="text-lg text-gray-800 font-medium">
                            <%= new Date(event.startDatetime).toLocaleString([], { dateStyle: 'long', timeStyle: 'short' }) %>
                        </p>
                        <!-- Alpine.js dynamic label -->
                        <p class="text-sm text-blue-600 font-semibold italic bg-blue-50 px-2 py-0.5 rounded inline-block mt-1">
                            Starts <span x-text="relativeTime"></span>
                        </p>
                    </div>
                </div>

                <!-- Capacity -->
                <div class="flex items-start gap-3">
                    <div class="mt-1 text-blue-600">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm font-bold uppercase tracking-wider text-gray-500">Capacity</p>
                        <p class="text-lg text-gray-800 font-medium">
                            <%= event.capacity ? event.capacity : "Unlimited" %>
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Description section -->
        <section class="p-6 md:p-8 bg-gray-50 border-t border-gray-200">
            <h3 class="text-xl font-bold text-gray-900 mb-4">About this Event</h3>
            <div class="prose text-gray-600 leading-relaxed max-w-none">
                <%= event.description %>
            </div>
        </section>

        <!-- Footer Section -->
        <footer class="p-6 md:p-8 bg-white border-t border-gray-200">
            <div class="user-actions">
                <% if (session?.user && (session.user.id === event.organizerId || session.user.role === 'admin')) { %>
                    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
                        <p class="text-blue-800 font-bold flex items-center gap-2 mb-4">Organizer View</p>
                        <div class="flex flex-wrap gap-3">
                            <a href="/events/<%= event.id %>/edit" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded-lg transition-colors">Edit Event</a>
                            <button class="bg-white hover:bg-red-50 text-red-600 border border-red-200 font-bold py-2 px-6 rounded-lg transition-colors">Cancel Event</button>
                        </div>
                    </div>
                <% } else { %>
                    <div id="rsvp-section" class="flex flex-col md:flex-row md:items-center justify-between gap-4 bg-gray-50 p-6 rounded-lg border border-gray-200">
                        <p class="text-gray-700 font-medium">Attendees: <span class="text-2xl font-bold text-blue-600 ml-2"><%= event.attendeeCount || 0 %></span></p>
                        <% if (session?.user) { %>
                            <button hx-post="/events/<%= event.id %>/rsvp" hx-target="#rsvp-section" hx-swap="outerHTML" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-lg shadow-lg transition-all">RSVP Now</button>
                        <% } else { %>
                            <p class="text-sm text-gray-500">Please <a href="/login" class="text-blue-600 underline">login</a> to RSVP.</p>
                        <% } %>
                    </div>
                <% } %>
            </div>
        </footer>
    </article>
</main>
<!-- Mobile button option -->
<div class="flex flex-col sm:flex-row gap-3 w-full">
    <a href="/events/<%= event.id %>/edit" 
       class="w-full sm:w-auto text-center bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-xl transition-all shadow-lg">
       Edit Event
    </a>
    <button class="w-full sm:w-auto bg-white hover:bg-red-50 text-red-600 border border-red-200 font-bold py-3 px-8 rounded-xl transition-colors">
       Cancel Event
    </button>
</div>
<%- include('../partials/footer') %>

  <!-- Action buttons -->
  <div class="mt-8 flex flex-wrap gap-4">
    <button class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded-lg transition">
      RSVP Now
    </button>
    
    <% if (user && (user.id === event.organizerId || user.role === 'admin')) { %>
      <a href="/events/<%= event.id %>/edit" class="bg-gray-200 hover:bg-gray-300 text-gray-800 font-bold py-2 px-6 rounded-lg transition">
        Edit Event
      </a>
    <% } %>
  </div>
</main>
