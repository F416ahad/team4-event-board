<!-- Main Container: Responsive padding (1rem on mobile, 2rem on tablet/desktop) -->
<main class="container mx-auto py-8 px-4 md:px-8 max-w-4xl">
  
  <!-- Header Section -->
  <div class="mb-6">
    <!-- Event Title: Large and Bold -->
    <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">
      <%= event.title %>
    </h1>

    <!-- Category Badge: Small, rounded, and colorful -->
    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800">
      <%= event.category %>
    </span>
  </div>

  <!-- Event Details Card: Bordered, rounded, and slightly shadowed -->
  <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
    <div class="p-6 space-y-4">
      
      <!-- Location Row -->
      <div class="flex items-start">
        <span class="font-semibold w-32 text-gray-700">Location:</span>
        <span class="text-gray-600"><%= event.location %></span>
      </div>

      <!-- Date/Time Row -->
      <div class="flex items-start">
        <span class="font-semibold w-32 text-gray-700">Date:</span>
        <div class="text-gray-600">
          <p><%= event.startDatetime.toLocaleDateString() %></p>
          <!-- This is where your Alpine.js relative time will go later! -->
        </div>
      </div>

      <!-- Capacity Row -->
      <div class="flex items-start">
        <span class="font-semibold w-32 text-gray-700">Capacity:</span>
        <span class="text-gray-600">
          <%= event.rsvpCount || 0 %> / <%= event.capacity || 'Unlimited' %> attendees
        </span>
      </div>

    </div>

    <!-- Description Section: Light gray background to separate from the metadata -->
    <div class="bg-gray-50 p-6 border-t border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900 mb-2">About this event</h2>
      <p class="text-gray-600 leading-relaxed">
        <%= event.description %>
      </p>
    </div>
  </div>

  <!-- Action Buttons -->
  <div class="mt-8 flex flex-wrap gap-4">
    <button class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded-lg transition">
      RSVP Now
    </button>
    
    <% if (user && (user.id === event.organizerId || user.role === 'admin')) { %>
      <a href="/events/<%= event.id %>/edit" class="bg-gray-200 hover:bg-gray-300 text-gray-800 font-bold py-2 px-6 rounded-lg transition">
        Edit Event
      </a>
    <% } %>
  </div>
</main>