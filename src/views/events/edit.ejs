<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <h1 class="text-3xl font-bold text-slate-900 mb-3">Edit Event</h1>
  <p class="text-slate-500">Update event fields. Past events cannot be edited.</p>
</section>

<% if (typeof error !== "undefined" && error) { %>
  <%- include("../partials/error", { message: error }) %>
<% } %>

<%
  function localDatetime(value) {
    if (!value) return "";
    const d = value instanceof Date ? value : new Date(value);
    if (Number.isNaN(d.getTime())) return "";
    const tzOffset = d.getTimezoneOffset() * 60000;
    return new Date(d.getTime() - tzOffset).toISOString().slice(0, 16);
  }
%>

<section class="max-w-2xl p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <form class="grid gap-4" method="post" action="/events/<%= event.id %>/edit">
    <div>
      <label for="title" class="block text-sm font-medium text-slate-700 mb-1">Title *</label>
      <input
        type="text"
        id="title"
        name="title"
        required
        value="<%= event.title %>"
        class="w-full px-3 py-2 border border-slate-300 rounded-xl bg-white focus:outline-2 focus:outline-blue-500/20 focus:border-blue-500"
      />
    </div>

    <div>
      <label for="category" class="block text-sm font-medium text-slate-700 mb-1">Category *</label>
      <select
        id="category"
        name="category"
        required
        class="w-full px-3 py-2 border border-slate-300 rounded-xl bg-white focus:outline-2 focus:outline-blue-500/20 focus:border-blue-500"
      >
        <% (typeof categories !== 'undefined' ? categories : ['academic','social','sports','arts','tech','other']).forEach(cat => { %>
          <option value="<%= cat %>" <%= event.category === cat ? "selected" : "" %>>
            <%= cat.charAt(0).toUpperCase() + cat.slice(1) %>
          </option>
        <% }) %>
      </select>
    </div>

    <div class="grid sm:grid-cols-2 gap-4">
      <div>
        <label for="date" class="block text-sm font-medium text-slate-700 mb-1">Starts *</label>
        <input
          type="datetime-local"
          id="date"
          name="date"
          required
          value="<%= localDatetime(event.date) %>"
          class="w-full px-3 py-2 border border-slate-300 rounded-xl bg-white focus:outline-2 focus:outline-blue-500/20 focus:border-blue-500"
        />
      </div>
      <div>
        <label for="endTime" class="block text-sm font-medium text-slate-700 mb-1">Ends</label>
        <input
          type="datetime-local"
          id="endTime"
          name="endTime"
          value="<%= localDatetime(event.endTime) %>"
          class="w-full px-3 py-2 border border-slate-300 rounded-xl bg-white focus:outline-2 focus:outline-blue-500/20 focus:border-blue-500"
        />
        <p class="text-xs text-slate-400 mt-1">Used to auto-archive the event when it ends.</p>
      </div>
    </div>

    <div>
      <label for="capacity" class="block text-sm font-medium text-slate-700 mb-1">Capacity (optional)</label>
      <input
        type="number"
        id="capacity"
        name="capacity"
        min="1"
        value="<%= event.capacity ?? '' %>"
        class="w-full px-3 py-2 border border-slate-300 rounded-xl bg-white focus:outline-2 focus:outline-blue-500/20 focus:border-blue-500"
      />
    </div>

    <div>
      <label for="status" class="block text-sm font-medium text-slate-700 mb-1">Status *</label>
      <select
        id="status"
        name="status"
        class="w-full px-3 py-2 border border-slate-300 rounded-xl bg-white focus:outline-2 focus:outline-blue-500/20 focus:border-blue-500"
      >
        <option value="active" <%= event.status === "active" ? "selected" : "" %>>Active</option>
        <option value="cancelled" <%= event.status === "cancelled" ? "selected" : "" %>>Cancelled</option>
      </select>
    </div>

    <button type="submit" class="mt-2 px-4 py-2.5 rounded-lg bg-blue-600 text-white font-medium cursor-pointer hover:bg-blue-700">
      Save Changes
    </button>
  </form>

  <div class="mt-6 pt-4 border-t border-slate-200">
    <a href="/events/<%= event.id %>" class="text-blue-600 hover:underline">&larr; Back to Event</a>
  </div>
</section>
