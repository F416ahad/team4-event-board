<%#
  Attendee list panel.
  Used inline on the event detail page (lazy-loaded via HTMX behind an
  Alpine toggle) and as the body of the standalone /events/:id/attendees page.
  Expects: attendees = { attending: [], waitlisted: [], cancelled: [] }
%>

<%
  const groups = [
    {
      key: "attending",
      label: "Attending",
      headingClass: "text-emerald-700",
      pillClass: "bg-emerald-100 text-emerald-800 border-emerald-200",
      ringClass: "ring-1 ring-emerald-100",
    },
    {
      key: "waitlisted",
      label: "Waitlisted",
      headingClass: "text-amber-700",
      pillClass: "bg-amber-100 text-amber-800 border-amber-200",
      ringClass: "ring-1 ring-amber-100",
    },
    {
      key: "cancelled",
      label: "Cancelled",
      headingClass: "text-slate-600",
      pillClass: "bg-slate-100 text-slate-700 border-slate-200",
      ringClass: "ring-1 ring-slate-100",
    },
  ];

  function fmtRsvpTime(value) {
    const d = value instanceof Date ? value : new Date(value);
    if (Number.isNaN(d.getTime())) return "";
    return d.toLocaleString([], {
      month: "short",
      day: "numeric",
      hour: "numeric",
      minute: "2-digit",
    });
  }

  const totalCount =
    (attendees.attending?.length || 0) +
    (attendees.waitlisted?.length || 0) +
    (attendees.cancelled?.length || 0);
%>

<div class="grid gap-4 sm:gap-5">
  <% if (totalCount === 0) { %>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-6 text-center text-sm text-slate-500">
      No RSVPs for this event yet.
    </div>
  <% } %>

  <% groups.forEach(group => { %>
    <% const list = attendees[group.key] || []; %>
    <section class="rounded-xl border border-slate-200 bg-white shadow-sm overflow-hidden <%= group.ringClass %>">
      <header class="flex items-center justify-between gap-3 px-4 py-2.5 border-b border-slate-200 bg-slate-50/60">
        <h4 class="flex items-center gap-2 text-sm font-semibold <%= group.headingClass %>">
          <%= group.label %>
        </h4>
        <span class="inline-flex items-center justify-center min-w-[1.75rem] h-6 px-2 rounded-full border text-xs font-semibold <%= group.pillClass %>">
          <%= list.length %>
        </span>
      </header>

      <% if (list.length === 0) { %>
        <p class="px-4 py-3 text-xs italic text-slate-400">No one in this group.</p>
      <% } else { %>
        <ul class="divide-y divide-slate-100">
          <% list.forEach(rsvp => { %>
            <li class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 sm:gap-3 px-4 py-2.5 text-sm hover:bg-slate-50">
              <span class="font-medium text-slate-800 truncate"><%= rsvp.displayName %></span>
              <span class="text-xs text-slate-400 shrink-0">
                RSVPed <%= fmtRsvpTime(rsvp.createdAt) %>
              </span>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </section>
  <% }) %>
</div>
