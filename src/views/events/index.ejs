<%# 
  Events list page.
  Feature 6: Polished Filter Bar with HTMX and Tailwind CSS.
%>

<!-- Page Header Section -->
<section class="mb-8 p-8 border border-slate-200 rounded-3xl bg-gradient-to-br from-white to-slate-50 shadow-sm">
  <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
    <div>
      <h1 class="text-4xl font-extrabold text-slate-900 mb-2 tracking-tight">All Events</h1>
      <p class="text-slate-500 text-lg">
        Find your next experience. Browse, filter, and RSVP.
      </p>
    </div>
    
    <%# Create new event button - Moved into header for better layout %>
    <div class="shrink-0">
      <a href="/events/new" class="inline-flex items-center px-6 py-3 rounded-xl bg-blue-600 text-white font-bold hover:bg-blue-700 transition-all shadow-md hover:shadow-lg transform hover:-translate-y-0.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Create Event
      </a>
    </div>
  </div>
</section>

<%# Feature 6: Polished Filter Bar Section %>
<section class="mb-10">
  <div class="bg-white p-2 rounded-2xl border border-slate-200 shadow-sm">
    <form hx-get="/events" 
          hx-target="#event-list-container" 
          hx-trigger="change" 
          hx-push-url="true" 
          class="flex flex-wrap md:flex-nowrap gap-2 items-center">
      
      <!-- Category Dropdown Wrapper -->
      <div class="flex-1 min-w-[200px] relative group">
        <div class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 11h.01M7 15h.01M13 7h.01M13 11h.01M13 15h.01M17 7h.01M17 11h.01M17 15h.01" />
          </svg>
        </div>
        <select name="category" 
                class="w-full pl-10 pr-4 py-3 rounded-xl border-transparent bg-slate-50 text-slate-700 font-medium text-sm focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all appearance-none cursor-pointer">
          <option value="all" <%= filters?.category === 'all' ? 'selected' : '' %>>All Categories</option>
          <option value="Academic" <%= filters?.category === 'Academic' ? 'selected' : '' %>>📚 Academic</option>
          <option value="Social" <%= filters?.category === 'Social' ? 'selected' : '' %>>🎉 Social</option>
        </select>
      </div>

      <!-- Vertical Divider for Desktop -->
      <div class="hidden md:block h-8 w-px bg-slate-200"></div>

      <!-- Timeframe Dropdown Wrapper -->
      <div class="flex-1 min-w-[200px] relative">
        <div class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <select name="timeframe" 
                class="w-full pl-10 pr-4 py-3 rounded-xl border-transparent bg-slate-50 text-slate-700 font-medium text-sm focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all appearance-none cursor-pointer">
          <option value="all-upcoming" <%= filters?.timeframe === 'all-upcoming' ? 'selected' : '' %>>All Upcoming</option>
          <option value="this-week" <%= filters?.timeframe === 'this-week' ? 'selected' : '' %>>This Week</option>
          <option value="this-weekend" <%= filters?.timeframe === 'this-weekend' ? 'selected' : '' %>>This Weekend</option>
        </select>
      </div>

      <!-- Search/Submit Button -->
      <button type="submit" 
              class="w-full md:w-auto px-8 py-3 bg-slate-900 text-white font-bold text-sm rounded-xl hover:bg-blue-600 transition-all shadow-md active:scale-95">
        Apply Filters
      </button>
    </form>
  </div>
</section>

<%# Display any page-level error %>
<% if (typeof error !== 'undefined' && error) { %>
  <%- include("../partials/error", { message: error }) %>
<% } %>

<%# Events list container - This is the target for HTMX updates %>
<div id="event-list-container" class="min-h-[400px]">
  <%- include("../partials/event-list") %>
</div>