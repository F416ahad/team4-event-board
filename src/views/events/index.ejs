<%#
  Events list page.
  Shows all events with links to view details. Filter bar above the list.
%>

<%# Contextual back link, above the hero %>
<div class="mb-3">
  <a href="/dashboard" class="inline-flex items-center gap-1 text-sm text-slate-500 hover:text-indigo-700 transition-colors">
    &larr; Back to dashboard
  </a>
</div>

<section class="mb-5 p-5 sm:p-6 border border-slate-200 rounded-2xl bg-gradient-to-br from-white to-indigo-50/40 shadow-sm">
  <div class="flex items-start gap-3">
    <span class="inline-flex shrink-0 items-center justify-center w-9 h-9 rounded-lg bg-gradient-to-br from-indigo-500 to-blue-600 text-white shadow-sm">
      <svg class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path d="M5.75 2a.75.75 0 01.75.75V4h7V2.75a.75.75 0 011.5 0V4h.25A2.75 2.75 0 0118 6.75v8.5A2.75 2.75 0 0115.25 18H4.75A2.75 2.75 0 012 15.25v-8.5A2.75 2.75 0 014.75 4H5V2.75A.75.75 0 015.75 2z"/>
      </svg>
    </span>
    <div>
      <h1 class="text-2xl sm:text-3xl font-bold text-slate-900">All events</h1>
      <p class="mt-1 text-sm text-slate-500">
        Browse upcoming events. Click any one to view details, RSVP, or leave a comment.
      </p>
    </div>
  </div>
</section>

<%# Filter bar with HTMX %>
<section class="mb-5 p-4 bg-white border border-slate-200 rounded-xl shadow-sm">
  <form hx-get="/events"
        hx-target="#event-list-container"
        hx-trigger="change"
        hx-push-url="true"
        class="flex flex-wrap gap-4 items-end">

    <div class="flex flex-col">
      <label class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Category</label>
      <select name="category" class="rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-200 focus:border-indigo-400">
        <option value="all" <%= filters?.category === 'all' ? 'selected' : '' %>>All categories</option>
        <option value="academic" <%= filters?.category === 'academic' ? 'selected' : '' %>>Academic</option>
        <option value="social" <%= filters?.category === 'social' ? 'selected' : '' %>>Social</option>
        <option value="sports" <%= filters?.category === 'sports' ? 'selected' : '' %>>Sports</option>
        <option value="arts" <%= filters?.category === 'arts' ? 'selected' : '' %>>Arts</option>
        <option value="tech" <%= filters?.category === 'tech' ? 'selected' : '' %>>Tech</option>
        <option value="other" <%= filters?.category === 'other' ? 'selected' : '' %>>Other</option>
      </select>
    </div>

    <div class="flex flex-col">
      <label class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Timeframe</label>
      <select name="timeframe" class="rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-200 focus:border-indigo-400">
        <option value="all-upcoming" <%= filters?.timeframe === 'all-upcoming' ? 'selected' : '' %>>All upcoming</option>
        <option value="this-week" <%= filters?.timeframe === 'this-week' ? 'selected' : '' %>>This week</option>
        <option value="this-weekend" <%= filters?.timeframe === 'this-weekend' ? 'selected' : '' %>>This weekend</option>
      </select>
    </div>

    <button type="submit" class="px-4 py-2 bg-slate-700 text-white text-sm font-medium rounded-lg hover:bg-slate-800 transition-colors">
      Filter
    </button>
  </form>
</section>

<%# Display any page-level error %>
<% if (typeof error !== 'undefined' && error) { %>
  <%- include("../partials/error", { message: error }) %>
<% } %>

<%# Events list container — HTMX swap target %>
<div id="event-list-container">
  <%- include("../partials/event-list") %>
</div>
