<%- include('../partials/header') %>

<!-- Page Header Section -->
<section class="mb-8 p-8 border border-slate-200 rounded-3xl bg-gradient-to-br from-white to-slate-50 shadow-sm">
  <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
    <div>
      <h1 class="text-4xl font-extrabold text-slate-900 mb-2 tracking-tight">All Events</h1>
      <p class="text-slate-500 text-lg">Browse, filter, and find your next experience.</p>
    </div>
    <div class="shrink-0">
      <a href="/events/new" class="inline-flex items-center px-6 py-3 rounded-xl bg-blue-600 text-white font-bold hover:bg-blue-700 transition-all shadow-md">
        + Create Event
      </a>
    </div>
  </div>
</section>

<%# Feature 6: Filter Bar with Alpine.js Logic %>
<section class="mb-10">
  <div class="bg-white p-2 rounded-2xl border border-slate-200 shadow-sm">
    <!-- 1. Added x-data here to track local state of filters -->
    <form x-data="{ 
            category: '<%= filters?.category || 'all' %>', 
            timeframe: '<%= filters?.timeframe || 'all-upcoming' %>' 
          }"
          hx-get="/events" 
          hx-target="#event-list-container" 
          hx-trigger="change" 
          hx-push-url="true" 
          class="flex flex-wrap md:flex-nowrap gap-2 items-center">
      
      <!-- Category Dropdown -->
      <div class="flex-1 min-w-[200px] relative">
        <select name="category" 
                x-model="category"
                class="w-full pl-4 pr-4 py-3 rounded-xl border-transparent bg-slate-50 text-slate-700 font-medium text-sm focus:bg-white focus:ring-2 focus:ring-blue-500 transition-all appearance-none cursor-pointer">
          <option value="all">All Categories</option>
          <option value="Academic">📚 Academic</option>
          <option value="Social">🎉 Social</option>
        </select>
      </div>

      <!-- Timeframe Dropdown -->
      <div class="flex-1 min-w-[200px] relative">
        <select name="timeframe" 
                x-model="timeframe"
                class="w-full pl-4 pr-4 py-3 rounded-xl border-transparent bg-slate-50 text-slate-700 font-medium text-sm focus:bg-white focus:ring-2 focus:ring-blue-500 transition-all appearance-none cursor-pointer">
          <option value="all-upcoming">All Upcoming</option>
          <option value="this-week">This Week</option>
          <option value="this-weekend">This Weekend</option>
        </select>
      </div>

      <!-- Buttons Area -->
      <div class="flex items-center gap-4 w-full md:w-auto px-2">
        <button type="submit" 
                class="flex-1 md:flex-none px-8 py-3 bg-slate-900 text-white font-bold text-sm rounded-xl hover:bg-blue-600 transition-all shadow-md">
          Apply
        </button>

        <!-- 2. Clear Filters Link: Only shows if filters are NOT at default values -->
        <a href="/events" 
           x-show="category !== 'all' || timeframe !== 'all-upcoming'" 
           x-transition:enter="transition ease-out duration-300"
           x-transition:enter-start="opacity-0 scale-90"
           x-transition:enter-end="opacity-100 scale-100"
           class="text-sm font-bold text-red-500 hover:text-red-700 whitespace-nowrap"
           style="display: none;"> <!-- style prevents 'flicker' on page load -->
          Clear All
        </a>
      </div>
    </form>
  </div>
</section>

<div id="event-list-container">
  <%- include("../partials/event-list") %>
</div>

<%- include('../partials/footer') %>