<%- include('../partials/header') %>

<!-- Page Header Section -->
<section class="mb-8 p-8 border border-slate-200 rounded-3xl bg-gradient-to-br from-white to-slate-50 shadow-sm">
  <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
    <div>
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-slate-900 mb-2 tracking-tight">All Events</h1>
      <p class="text-slate-500 text-sm md:text-lg italic">Sprint 4: Responsive & Filtered</p>
    </div>
    <div class="shrink-0">
      <a href="/events/new" class="inline-flex items-center px-6 py-3 rounded-xl bg-blue-600 text-white font-bold hover:bg-blue-700 transition-all shadow-md active:scale-95">
        + Create Event
      </a>
    </div>
  </div>
</section>

<%# Feature 6: Final Polished Filter Bar %>
<section class="mb-10">
  <div class="bg-white p-2 rounded-2xl border border-slate-200 shadow-md">
    <form x-data="{ 
            category: '<%= filters?.category || 'all' %>', 
            timeframe: '<%= filters?.timeframe || 'all-upcoming' %>' 
          }"
          hx-get="/events" 
          hx-target="#event-list-container" 
          hx-trigger="change" 
          hx-push-url="true" 
          class="flex flex-col md:flex-row gap-2 items-center">
      
      <!-- Category Dropdown -->
      <div class="w-full md:flex-1 relative">
        <select name="category" 
                x-model="category"
                class="w-full pl-4 pr-10 py-3 rounded-xl border-slate-100 bg-slate-50 text-slate-700 font-medium text-sm focus:bg-white focus:ring-2 focus:ring-blue-500 transition-all cursor-pointer appearance-none">
          <option value="all">All Categories</option>
          <option value="Academic">📚 Academic</option>
          <option value="Social">🎉 Social</option>
        </select>
        <div class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </div>
      </div>

      <!-- Timeframe Dropdown -->
      <div class="w-full md:flex-1 relative">
        <select name="timeframe" 
                x-model="timeframe"
                class="w-full pl-4 pr-10 py-3 rounded-xl border-slate-100 bg-slate-50 text-slate-700 font-medium text-sm focus:bg-white focus:ring-2 focus:ring-blue-500 transition-all cursor-pointer appearance-none">
          <option value="all-upcoming">All Upcoming</option>
          <option value="this-week">This Week</option>
          <option value="this-weekend">This Weekend</option>
        </select>
        <div class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </div>
      </div>

      <!-- Actions Group -->
      <div class="flex items-center justify-between w-full md:w-auto px-4 py-2 md:py-0 gap-4">
        <button type="submit" 
                class="hidden md:block px-6 py-3 bg-slate-900 text-white font-bold text-sm rounded-xl hover:bg-blue-600 transition-all shadow-sm">
          Filter
        </button>

        <a href="/events" 
           hx-boost="true"
           x-show="category !== 'all' || timeframe !== 'all-upcoming'" 
           x-transition
           class="text-sm font-bold text-red-500 hover:text-red-700 decoration-2 underline-offset-4 hover:underline"
           style="display: none;">
          Clear Filters
        </a>
      </div>
    </form>
  </div>
</section>

<!-- Target for HTMX Swaps -->
<div id="event-list-container" class="min-h-[300px]">
  <%- include("../partials/event-list") %>
</div>

<%- include('../partials/footer') %>