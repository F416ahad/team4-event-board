<%# 
  Events list page.
  Shows all events with links to view details.
  Uses Tailwind CSS classes matching the auth templates.
%>

<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <h1 class="text-3xl font-bold text-slate-900 mb-3">All Events</h1>
  <p class="text-slate-500">
    Browse events and click "View Details" to RSVP or leave comments.
  </p>
</section>

<%# Display any page-level error (e.g., failed to load events) %>
<% if (typeof error !== 'undefined' && error) { %>
  <%- include("../partials/error", { message: error }) %>
<% } %>

<%# Create new event button (visible only for users with staff/admin role) %>
<div class="mb-5 text-right">
  <a href="/events/new" class="inline-block px-4 py-2 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-700">
    + Create New Event
  </a>
</div>

<%# Events list using same card style as existing users list %>
<div class="grid gap-4">
  <% if (events && events.length) { %>
    <% events.forEach(event => { %>
      <div class="flex items-center justify-between gap-4 p-5 border border-slate-200 rounded-xl bg-white shadow-md">
        <div>
          <h2 class="text-xl font-semibold text-slate-900"><%= event.title %></h2>
          <p class="text-sm text-slate-500 mt-1">
            <strong>Date:</strong> <%= new Date(event.date).toLocaleString() %>
          </p>
          <p class="text-sm text-slate-500">
            <strong>Status:</strong> 
            <span class="capitalize <%= event.status === 'cancelled' ? 'text-red-600' : 'text-green-600' %>">
              <%= event.status %>
            </span>
          </p>
        </div>
        <div>
          <a href="/events/<%= event.id %>" class="px-4 py-2 rounded-lg bg-slate-600 text-white font-medium hover:bg-slate-700">
            View Details
          </a>
        </div>
      </div>
    <% }); %>
  <% } else { %>
    <div class="p-6 text-center border border-slate-200 rounded-xl bg-slate-50">
      <p class="text-slate-500">No events found. Create one to get started!</p>
    </div>
  <% } %>
</div>