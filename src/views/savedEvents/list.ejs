<%- include("../partials/header") %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  
  <div class="mb-8 border-b border-slate-200 pb-5 flex flex-col sm:flex-row justify-between items-start sm:items-end">
    <div>
      <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">My Saved Events</h1>
      <p class="mt-2 text-sm text-slate-500">Events you've bookmarked to review later.</p>
    </div>
    <a href="/events" class="mt-4 sm:mt-0 text-sm font-medium text-blue-600 hover:text-blue-800 flex items-center gap-1 transition-colors">
      &larr; Browse more events
    </a>
  </div>

  <div id="savedList" class="mt-6">
    <% if (events.length === 0) { %>
      <div class="text-center py-16 bg-slate-50 rounded-2xl border border-slate-200 border-dashed">
        <svg class="mx-auto h-12 w-12 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
        </svg>
        <h3 class="mt-4 text-lg font-medium text-slate-900">No saved events</h3>
        <p class="mt-1 text-sm text-slate-500 mb-6">You haven't bookmarked any events yet.</p>
        <a href="/events" class="inline-flex items-center px-5 py-2.5 border border-transparent text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 shadow-sm transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
          Find events to save
        </a>
      </div>
    <% } else { %>
      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 p-0 m-0">
        
        <% events.forEach(function(event) { %>
          <li class="flex flex-col bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            
            <div class="p-6 flex-grow">
              <h3 class="text-xl font-bold text-slate-900 mb-3 truncate"><%= event.title %></h3>
              
              <div class="space-y-2">
                <p class="text-sm text-slate-600 flex items-center gap-2">
                  <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                  <%= event.location %>
                </p>
                <p class="text-sm text-slate-600 flex items-center gap-2">
                  <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                  <%= new Date(event.startDatetime).toLocaleDateString(undefined, { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' }) %>
                </p>
              </div>
            </div>
            
            <div class="px-6 py-4 bg-slate-50 border-t border-slate-100 flex items-center justify-between">
              <a href="/events/<%= event.id %>" class="text-sm font-medium text-blue-600 hover:text-blue-800 hover:underline transition-colors">
                View Details
              </a>
              
              <button 
                hx-post="/events/<%= event.id %>/save" 
                hx-target="closest li" 
                hx-swap="outerHTML swap:0.5s"
                class="flex items-center gap-1 px-3 py-1.5 text-sm font-medium text-red-600 bg-red-50 border border-red-200 rounded-lg hover:bg-red-100 transition-colors"
                title="Remove from saved"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"></path></svg>
                Remove
              </button>
            </div>

          </li>
        <% }); %>
        
      </ul>
    <% } %>
  </div>
</div>

<%- include("../partials/footer") %>