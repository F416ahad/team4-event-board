<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <h1 class="text-3xl font-bold text-slate-900 mb-3">Sign In</h1>
  <p class="text-slate-500">
    Log in with one of the demo accounts below to access the application.
  </p>
</section>

<% if (pageError) { %>
  <%- include("partials/error", { message: pageError }) %>
<% } %>

<section class="max-w-3xl p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <div class="mb-4">
    <h2 class="text-xl font-semibold mb-2">Log In</h2>
    <p class="text-slate-500">
      This starter uses three in-memory demo users with hashed passwords so you
      can focus on building your project features.
    </p>
  </div>

  <form class="grid gap-2.5" method="post" action="/login">
    <label for="email" class="text-sm font-medium">Email</label>
    <input
      id="email"
      name="email"
      type="email"
      autocomplete="username"
      required
      class="w-full px-3 py-2.5 border border-slate-300 rounded-xl bg-white focus:outline-2 focus:outline-blue-500/20 focus:border-blue-500"
    />

    <label for="password" class="text-sm font-medium">Password</label>
    <input
      id="password"
      name="password"
      type="password"
      autocomplete="current-password"
      required
      class="w-full px-3 py-2.5 border border-slate-300 rounded-xl bg-white focus:outline-2 focus:outline-blue-500/20 focus:border-blue-500"
    />

    <button
      type="submit"
      class="mt-1 px-4 py-2.5 rounded-lg bg-blue-600 text-white font-medium cursor-pointer hover:bg-blue-700"
    >
      Log in
    </button>
  </form>

  <div class="mt-5 pt-5 border-t border-slate-200">
    <h3 class="text-base font-semibold mb-2">Demo Users</h3>
    <ul class="list-disc pl-5 space-y-1 text-sm">
      <li><code class="bg-slate-100 px-1 rounded">admin@app.test</code> / <code class="bg-slate-100 px-1 rounded">password123</code> / <code class="bg-slate-100 px-1 rounded">Admin</code></li>
      <li><code class="bg-slate-100 px-1 rounded">staff@app.test</code> / <code class="bg-slate-100 px-1 rounded">password123</code> / <code class="bg-slate-100 px-1 rounded">Staff</code></li>
      <li><code class="bg-slate-100 px-1 rounded">user@app.test</code> / <code class="bg-slate-100 px-1 rounded">password123</code> / <code class="bg-slate-100 px-1 rounded">User</code></li>
    </ul>
  </div>
</section>
