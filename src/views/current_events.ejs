<%- include("../partials/header") %>

<div class="event-container">

  <!-- EVENT HEADER -->
  <div class="event-header">
    <h1><%= event.title %></h1>

    <p>
      <strong>Date:</strong>
      <%= new Date(event.date).toLocaleString() %>
    </p>

    <p>
      <strong>Category:</strong>
      <%= event.category %>
    </p>

    <p>
      <strong>Capacity:</strong>
      <%= event.capacity %>
    </p>
  </div>

  <hr />

  <!-- USER RSVP STATUS -->
  <div class="user-status">
    <h2>Your RSVP Status</h2>

    <% if (!currentUserRsvp) { %>
      <p>You have not RSVP’d for this event.</p>
    <% } else { %>

      <% if (currentUserRsvp.status === "ATTENDING") { %>
        <p class="badge badge-green">You are attending this event</p>
      <% } %>

      <% if (currentUserRsvp.status === "WAITLISTED") { %>
        <p class="badge badge-yellow">
          You are waitlisted — Position:
          <%= currentUserRsvp.waitlistPosition %>
        </p>
      <% } %>

      <% if (currentUserRsvp.status === "CANCELLED") { %>
        <p class="badge badge-gray">You are not registered</p>
      <% } %>

      <!-- CANCEL BUTTON -->
      <% if (currentUserRsvp.status !== "CANCELLED") { %>
        <form
          method="POST"
          action="/events/<%= event.id %>/rsvp/cancel"
        >
          <button type="submit" class="btn btn-danger">
            Cancel RSVP
          </button>
        </form>
      <% } %>

    <% } %>
  </div>

  <hr />

  <!-- RSVP LIST -->
  <div class="rsvp-list">
    <h2>Attendees & Waitlist</h2>

    <% if (!event.rsvps || event.rsvps.length === 0) { %>
      <p>No RSVPs yet.</p>
    <% } %>

    <% event.rsvps.forEach(rsvp => { %>

      <div class="rsvp-card">

        <!-- MEMBER NAME -->
        <p class="member-name">
          <%= rsvp.member.displayName %>
        </p>

        <!-- STATUS BADGE -->
        <% if (rsvp.status === "ATTENDING") { %>
          <span class="badge badge-green">Attending</span>
        <% } %>

        <% if (rsvp.status === "WAITLISTED") { %>
          <span class="badge badge-yellow">Waitlisted</span>

          <p class="position">
            Position:
            <%= rsvp.waitlistPosition %>
          </p>
        <% } %>

        <% if (rsvp.status === "CANCELLED") { %>
          <span class="badge badge-gray">Cancelled</span>
        <% } %>

      </div>

    <% }) %>

  </div>

</div>

<%- include("../partials/footer") %>