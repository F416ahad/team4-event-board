generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Event {
  id          String   @id @default(uuid())
  title       String
  date        DateTime
  category    String
  capacity    Int
  organizerId String
  status      EventStatus
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rsvps RSVP[]
}

model Member {
  id          String   @id @default(uuid())
  email       String   @unique
  displayName String
  createdAt   DateTime @default(now())

  rsvps RSVP[]
}

model RSVP {
  id               String      @id @default(uuid())
  eventId          String
  memberId         String
  status           RSVPStatus
  waitlistPosition Int?        // null if ATTENDING
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  event  Event  @relation(fields: [eventId], references: [id])
  member Member @relation(fields: [memberId], references: [id])

  @@unique([eventId, memberId])
  @@index([eventId, status, createdAt])
}

enum RSVPStatus {
  ATTENDING
  WAITLISTED
  CANCELLED
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  PAST
}