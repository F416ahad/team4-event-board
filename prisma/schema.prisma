generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid()) // random UUID (Universally Unique Identifier)
  email        String    @unique
  displayName  String
  role         String    // "admin", "staff", "user"
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  events       Event[]   @relation("EventCreator") // Names a relation between two models (tables), this case EventCreator
  rsvps        Rsvp[]
  comments     Comment[]
  
  // Added for Feature 14 (Save for Later)
  savedEvents  SavedEvent[]
}

model Event {
  id              String    @id @default(uuid())
  title           String
  description     String?   // Added for Feature 10 Search
  location        String?   // Added for Feature 10 Search
  capacity        Int?
  status          String    @default("active") // "active" | "past" | "cancelled" | "published"
  date            DateTime
  endTime         DateTime? // Kept your teammate's new field!
  createdByUserId String
  createdBy       User      @relation("EventCreator", fields: [createdByUserId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  rsvps           Rsvp[]
  comments        Comment[]
  
  // Added for Feature 14 (Save for Later)
  savedEvents     SavedEvent[]
}

model Rsvp {
  id               String   @id @default(uuid())
  status           String   // "going" | "waitlisted" | "cancelled"
  waitlistPosition Int?     
  userId           String
  eventId          String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId]) // One RSVP per user per event, each pair must be unique
}

model Comment {
  id          String   @id @default(uuid())
  content     String
  displayName String
  userId      String
  eventId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])
}

// ── Feature 14: Save for Later ───────────────────────────────────────

model SavedEvent {
  id        String   @id @default(uuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId]) 
}