model User {
  id           String    @id @default(uuid()) // random UUID (Universally Unique Identifier)
  email        String    @unique
  displayName  String
  role         String    // "admin", "staff", "user"
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  events   Event[]   @relation("EventCreator") // Names a relation between two models (tables), this case EventCreator
  rsvps    Rsvp[]
  comments Comment[]
}

model Event {
  id               String    @id @default(uuid())
  title            String
  capacity         Int?
  status           String    @default("active") // "active" | "past" | "cancelled"
  date             DateTime
  endTime          DateTime?
  createdByUserId  String
  createdBy        User      @relation("EventCreator", fields: [createdByUserId], references: [id])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  rsvps    Rsvp[]
  comments Comment[]
}

model Rsvp {
  id        String   @id @default(uuid())
  status    String   // "going" | "waitlisted" | "cancelled"
  userId    String
  eventId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId]) // One RSVP per user per event, each pair must be unique
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  displayName String
  userId    String
  eventId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])
}